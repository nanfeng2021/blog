# 环境变量配置（不要提交到 Git）

# Docker Hub 认证
DOCKERHUB_USERNAME=nanfeng2021
DOCKERHUB_TOKEN=your-dockerhub-token

# Umami 统计
UMAMI_APP_SECRET=your-umami-secret-key

# Grafana 管理员密码
GRAFANA_ADMIN_PASSWORD=your-grafana-password

# SSL 证书路径
SSL_CERT_PATH=/etc/letsencrypt/live/ainanfeng.cn/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/ainanfeng.cn/privkey.pem

# 金丝雀发布比例（0.0-1.0）
CANARY_RATIO=0.1
